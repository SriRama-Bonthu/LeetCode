class Solution {
    public char findKthBit(int n, int k) {
        StringBuilder sb=new StringBuilder();
        sb.append("0");
        for(int i=1;i<n && sb.length()<k;i++){
            String s=sb.toString();
            sb.append(1);
            for(int j=s.length()-1;j>=0;j--){
                if(s.charAt(j)=='0'){
                    sb.append(1);
                }
                else{
                    sb.append(0);
                }
            }
        }
        return sb.charAt(k-1);
    }
}
