class Solution {
    public int countValidSubarrays(int[] nums, int x) {
        int c=0;
        for(int i=0;i<nums.length;i++){
            long sum=0;
            for(int j=i;j<nums.length;j++){
                sum=sum+nums[j];
                String s=String.valueOf(sum);
                if(sum%10==x && s.charAt(0)-'0'==x){
                    c++;
                }
            }
        }
        return c;
    }
}
