class Solution {
    public int minSwaps(int[][] grid) {
        int n=grid.length;
        int[] endZeroes=new int[n];
        // int[] needZeroes=new int[n];
        // int c=n;
        // for(int i=0;i<n;i++){
        //     needZeroes[i]=c-1;
        //     c=c-1;
        // }
        for(int i=0;i<n;i++){
            int j=n-1;
            while(j>=0 && grid[i][j--]==0){
                endZeroes[i]++;
            }
        }
        int steps=0;
        for(int i=0;i<n;i++){
            int needZeroes=n-i-1;
            int k=i;
            while(k<n && endZeroes[k]<needZeroes){
                k++;
            }
            if(k==n){
                return -1;
            }
            while(k<n && k>i){
                int temp=endZeroes[k];
                endZeroes[k]=endZeroes[k-1];
                endZeroes[k-1]=temp;
                steps++;
                k--;
            }
        }
        return steps;
    }
}
