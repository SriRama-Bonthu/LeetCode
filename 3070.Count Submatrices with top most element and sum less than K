class Solution {
    public int countSubmatrices(int[][] grid, int k) {
        int n=grid.length;
        int m=grid[0].length;
        int[][] pre=new int[n][m];
        // int[][] precol=new int[n][m];
        for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){
                int top=(i>0)?pre[i-1][j]:0;
                int diag=(i>0 && j>0)?pre[i-1][j-1]:0;
                int left=(j>0)?pre[i][j-1]:0;
                pre[i][j]=grid[i][j]+top+left-diag;
            }
        }
        int c=0;
        for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){
                c=(pre[i][j]<=k)?c+1:c;
            }
        }
        return c;
    }
}
