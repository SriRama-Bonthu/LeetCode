class Solution {
    public String reversePrefix(String s, int k) {
        char[] arr=new char[s.length()];
        int i=0;
        for(char c:s.toCharArray()){
            arr[i++]=c;
        }
        i=0;
        int j=k-1;
        while(i<=j){
            char temp=arr[i];
            arr[i]=arr[j];
            arr[j]=temp;
            i++;
            j--;
        }
        return String.valueOf(arr);
    }
}
