class Solution {
    public int[] platesBetweenCandles(String s, int[][] queries) {
        int n = s.length();
        int[] pre = new int[n];
        int[] left = new int[n];
        int[] right = new int[n];
        
        // Prefix sum of plates
        pre[0] = (s.charAt(0) == '*') ? 1 : 0;
        for (int i = 1; i < n; i++) {
            pre[i] = pre[i - 1] + (s.charAt(i) == '*' ? 1 : 0);
        }
        
        // Nearest candle to the left
        int lastCandle = -1;
        for (int i = 0; i < n; i++) {
            if (s.charAt(i) == '|') lastCandle = i;
            left[i] = lastCandle;
        }
        
        // Nearest candle to the right
        lastCandle = -1;
        for (int i = n - 1; i >= 0; i--) {
            if (s.charAt(i) == '|') lastCandle = i;
            right[i] = lastCandle;
        }
        
        // Answer queries
        int[] res = new int[queries.length];
        for (int q = 0; q < queries.length; q++) {
            int l = queries[q][0];
            int r = queries[q][1];
            int x = right[l];   // first candle ≥ l
            int y = left[r];    // last candle ≤ r
            if (x != -1 && y != -1 && x < y) {
                res[q] = pre[y] - pre[x];
            } else {
                res[q] = 0;
            }
        }
        return res;
    }
}
