class Solution {
    public int binaryGap(int n) {
        String s=Integer.toBinaryString(n);
        int i=0;
        for(int j=0;j<s.length();j++){
            if(s.charAt(j)=='1'){
                i=j;
                break;
            }
        }
        int max=0;
        for(int j=i+1;j<s.length();j++){
            if(s.charAt(j)=='1'){
                max=Math.max(j-i,max);
                i=j;
            }
        }
        return max;
    }
}
